# API Keys - Copy this file to .env and fill in your keys
# DO NOT commit .env file with actual keys!

# Google Gemini API Key (main RAG pipeline)
GOOGLE_API_KEY=your_gemini_api_key_here

# OpenAI API Key (RAGAS evaluation - LLM judge)
OPENAI_API_KEY=your_openai_api_key_here

# Groq API Key (optional, for evaluation experiments only)
GROQ_API_KEY=your_groq_api_key_here
